                <span class="absolute inset-0 w-full h-full bg-grad-animated bg-[length:200%_auto] animate-shimmer opacity-0 hover:opacity-100 transition-opacity duration-300"></span>
                <span id="texto-home-heroBtn" class="relative z-10"><%= siteData.home.heroBtn %></span>
            </a>
        </div>
    </div>
</div>


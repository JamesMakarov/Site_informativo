</section>

<section class="py-24 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 transition-colors duration-500">
    <div class="max-w-7xl mx-auto px-6">
        <div class="relative group/htitulo inline-block w-full text-center">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 right-1/4 bg-brand-accent text-white p-2 rounded-full shadow z-50 opacity-0 group-hover/htitulo:opacity-100 text-xs" data-pagina="home" data-chave="highlightSecTitulo">✏️</button><% } %>
            <h2 id="texto-home-highlightSecTitulo" class="hidden-scroll text-3xl font-extrabold text-brand-blue dark:text-white mb-12"><%= siteData.home.highlightSecTitulo %></h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="hidden-scroll delay-100 md:col-span-2 bg-grad-primary bg-[length:200%_auto] hover:animate-shimmer rounded-3xl p-10 text-white shadow-xl relative overflow-hidden transition-all duration-500 hover:-translate-y-2">
                <div class="relative z-10 flex flex-col h-full justify-between group/hcard">
                    <% if(isAdmin) { %>
                        <div class="absolute top-0 right-0 flex gap-2 opacity-0 group-hover/hcard:opacity-100 transition-opacity z-50">
                            <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="highlightBadge">Badge</button>
                            <button class="btn-editar-cms bg-orange-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="highlightTitulo">Título</button>
                            <button class="btn-editar-cms bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="highlightTexto">Texto</button>
                        </div>
                    <% } %>
                    <div>
                        <span id="texto-home-highlightBadge" class="bg-white/20 text-white text-xs font-bold px-4 py-1.5 rounded-full mb-6 inline-block backdrop-blur-sm shadow-sm border border-white/20"><%= siteData.home.highlightBadge %></span>
                        <h3 id="texto-home-highlightTitulo" class="text-3xl md:text-5xl font-extrabold mb-4 drop-shadow-md"><%= siteData.home.highlightTitulo %></h3>
                        <p id="texto-home-highlightTexto" class="text-blue-50 max-w-xl text-lg leading-relaxed"><%= siteData.home.highlightTexto %></p>
                    </div>
                    <div class="relative inline-block mt-10 w-max group/hbtn">
                        <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-4 bg-brand-primary text-white p-1 rounded-full shadow z-50 opacity-0 group-hover/hbtn:opacity-100 text-xs" data-pagina="home" data-chave="highlightBtn">✏️</button><% } %>
                        <a href="/noticias" class="nav-link inline-flex items-center gap-3 font-bold text-brand-accent bg-white px-6 py-3 rounded-full hover:bg-slate-50 transition-colors shadow-lg hover:scale-105">
                            <span id="texto-home-highlightBtn"><%= siteData.home.highlightBtn %></span> <span class="hover:translate-x-2 transition-transform">→</span>
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="hidden-scroll delay-200 bg-white dark:bg-slate-800 rounded-3xl p-10 shadow-xl border border-slate-100 dark:border-slate-700 transition-colors flex flex-col justify-center items-center text-center hover:-translate-y-2 duration-300 relative group/lit">
                <% if(isAdmin) { %>
                    <div class="absolute top-2 right-2 flex gap-1 opacity-0 group-hover/lit:opacity-100 transition-opacity z-50 flex-col">
                        <button class="btn-editar-cms bg-brand-accent text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="liturgiaIcon">Ícone</button>
                        <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="liturgiaTitulo">Título</button>
                        <button class="btn-editar-cms bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="home" data-chave="liturgiaTexto">Texto</button>
                    </div>
                <% } %>
                <div id="texto-home-liturgiaIcon" class="text-6xl mb-6 hover:rotate-12 transition-transform duration-500 drop-shadow-md cursor-default"><%= siteData.home.liturgiaIcon %></div>
                <h3 id="texto-home-liturgiaTitulo" class="text-2xl font-bold text-brand-blue dark:text-white mb-3"><%= siteData.home.liturgiaTitulo %></h3>
                <p id="texto-home-liturgiaTexto" class="text-slate-500 dark:text-slate-400 mb-8 leading-relaxed"><%= siteData.home.liturgiaTexto %></p>
                <div class="relative group/lbtn">
                    <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-6 bg-brand-primary text-white p-1 rounded-full shadow z-50 opacity-0 group-hover/lbtn:opacity-100 text-xs" data-pagina="home" data-chave="liturgiaBtn">✏️</button><% } %>
                    <button class="text-brand-primary dark:text-brand-accent font-bold hover:underline transition-colors flex items-center gap-2"><span id="texto-home-liturgiaBtn"><%= siteData.home.liturgiaBtn %></span> <span>→</span></button>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-24 bg-slate-100 dark:bg-slate-900 transition-colors duration-500 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-4xl mx-auto px-6">
        
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 hidden-scroll">
            <div class="relative group/faqtop inline-block w-full md:w-auto text-center md:text-left">
                <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-8 bg-brand-accent text-white p-2 rounded-full shadow z-50 opacity-0 group-hover/faqtop:opacity-100 text-xs" data-pagina="home" data-chave="faqTitulo">✏️</button><% } %>
                <h2 id="texto-home-faqTitulo" class="text-3xl md:text-5xl font-extrabold text-brand-blue dark:text-white"><%= siteData.home.faqTitulo %></h2>
            </div>
            
            <% if(isAdmin) { %>
                <button id="btn-adicionar-faq" class="bg-green-500 hover:bg-green-400 text-white w-10 h-10 rounded-full flex items-center justify-center text-2xl font-black shadow-lg transition-all hover:scale-110 hover:rotate-90 z-50 mt-4 md:mt-0" title="Adicionar Nova Pergunta">
                    +
                </button>
            <% } %>
        </div>
        
        <div class="space-y-4 max-h-[400px] overflow-y-auto pr-3 custom-scrollbar hidden-scroll delay-100">
            <% if(siteData.home.faqs && siteData.home.faqs.length > 0) { %>
                <% siteData.home.faqs.forEach((faq, index) => { %>
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 hover:-translate-y-1 transition-all relative group/faq">
                        
                        <% if(isAdmin) { %>
                            <div class="absolute top-2 right-2 flex gap-1 z-50 opacity-0 group-hover/faq:opacity-100 transition-opacity">
                                <button class="btn-editar-faq bg-blue-500 hover:bg-blue-400 text-white px-2 py-1 rounded shadow text-xs font-bold" data-index="<%= index %>" data-campo="pergunta">✏️ Pergunta</button>
                                <button class="btn-editar-faq bg-green-600 hover:bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-index="<%= index %>" data-campo="resposta">✏️ Resposta</button>
                                <button class="btn-remover-faq bg-red-600 hover:bg-red-500 text-white px-2 py-1 rounded shadow text-xs font-bold ml-2" data-index="<%= index %>" title="Remover Pergunta">🗑️</button>
                            </div>
                        <% } %>

                        <h3 class="text-lg font-bold text-brand-blue dark:text-white mb-2 flex items-center gap-2"><span>❓</span> <span id="texto-faq-<%= index %>-pergunta"><%= faq.pergunta %></span></h3>
                        <p id="texto-faq-<%= index %>-resposta" class="text-slate-600 dark:text-slate-400 pl-8"><%= faq.resposta %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-center text-slate-500 italic">Nenhuma pergunta cadastrada.</p>
            <% } %>
        </div>
    </div>
</section>


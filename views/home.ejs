                <a href="/historia" class="nav-link bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-brand-blue dark:text-white hover:border-brand-primary dark:hover:border-brand-accent px-8 py-4 rounded-full font-bold transition-all hover:scale-105 inline-block w-full">

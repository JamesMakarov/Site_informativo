        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 md:mb-10 hidden-scroll relative group gap-4">
            <div class="flex items-center gap-4">
                <h2 class="text-3xl md:text-5xl font-extrabold text-brand-blue dark:text-white leading-tight">Vidas Transformadas</h2>
                <% if(isAdmin) { %>
                    <button id="btn-adicionar-depoimento" class="bg-green-500 hover:bg-green-400 text-white w-8 h-8 md:w-10 md:h-10 rounded-full flex items-center justify-center text-xl md:text-2xl font-black shadow-lg transition-all hover:scale-110 hover:rotate-90 z-50 mb-1 shrink-0" title="Adicionar Novo Depoimento">+</button>
                <% } %>
            </div>
            
            <div class="hidden md:flex gap-3 md:gap-4 shrink-0">
                <button id="btn-prev" class="bg-slate-100 dark:bg-slate-800 hover:bg-brand-primary hover:text-white text-brand-blue dark:text-white w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center transition-all shadow-sm hover:-translate-y-1">
                    <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button id="btn-next" class="bg-slate-100 dark:bg-slate-800 hover:bg-brand-primary hover:text-white text-brand-blue dark:text-white w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center transition-all shadow-sm hover:-translate-y-1">
                    <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            </div>
        </div>
        
        <div class="hidden-scroll delay-100 w-full relative">
            
            <div class="md:hidden absolute right-0 top-1/2 -translate-y-1/2 w-12 h-12 bg-gradient-to-l from-white dark:from-slate-900 to-transparent z-10 pointer-events-none flex items-center justify-end text-slate-400 animate-pulse">
                <span class="text-2xl mr-2">›</span>
            </div>

            <div id="carousel-track" class="flex gap-4 md:gap-6 w-full pt-10 pb-16 scroll-livre overflow-x-auto snap-x snap-mandatory scroll-smooth items-stretch">
                
                <% siteData.home.depoimentos.forEach((dep, index) => { %>
                    <% 
                        const isBlue = index % 2 !== 0; 
                        const cardClass = isBlue ? 'bg-brand-blue dark:bg-slate-800 text-white border-brand-primary dark:border-brand-accent shadow-[0_10px_40px_-10px_rgba(29,78,216,0.3)] hover:shadow-2xl md:-translate-y-2 hover:md:-translate-y-6' : 'bg-slate-50 dark:bg-slate-800/80 p-6 md:p-10 text-slate-600 dark:text-slate-300 border-slate-100 dark:border-slate-700 shadow-md hover:shadow-2xl hover:md:-translate-y-4';
                        const pClass = isBlue ? 'text-blue-50 dark:text-slate-200' : 'text-slate-600 dark:text-slate-300';
                        const nameClass = isBlue ? 'text-white' : 'text-brand-blue dark:text-white';
                    %>

                    <div class="w-[85vw] sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] shrink-0 snap-start group/card relative flex flex-col">
                        
                        <% if(isAdmin) { %>
                            <div class="absolute -top-6 right-2 flex gap-1 z-20 opacity-0 group-hover/card:opacity-100 transition-opacity bg-white/80 dark:bg-slate-700/80 p-1.5 rounded-lg backdrop-blur-sm shadow-sm border border-slate-200 dark:border-slate-600">
                                <button class="btn-editar-depoimento bg-brand-accent text-white px-2 py-1 rounded shadow hover:scale-110 text-[10px] md:text-xs font-bold" data-index="<%= index %>" data-campo="texto" title="Editar Texto">✏️ Texto</button>
                                <button class="btn-remover-depoimento bg-red-600 text-white px-2 py-1 rounded shadow hover:scale-110 text-[10px] md:text-xs font-bold ml-1" data-index="<%= index %>" title="Apagar Depoimento">🗑️</button>
                            </div>
                        <% } %>

                        <div class="<%= cardClass %> p-6 md:p-10 rounded-2xl md:rounded-3xl relative border h-full flex flex-col flex-1 transition-all duration-300">
                            <div class="text-5xl md:text-7xl <%= isBlue ? 'text-brand-primary/40 dark:text-brand-accent/40' : 'text-brand-accent/20' %> absolute top-2 left-4 md:left-6 font-serif cursor-default">"</div>
                            
                            <p id="texto-dep-<%= index %>-texto" class="<%= pClass %> italic relative z-10 mt-4 md:mt-6 mb-6 md:mb-8 text-base md:text-lg leading-relaxed flex-1"><%= dep.texto %></p>
                            
                            <div class="flex items-center gap-3 md:gap-4 mt-auto relative group/autor pt-4 border-t <%= isBlue ? 'border-brand-primary/50 dark:border-slate-700' : 'border-slate-200 dark:border-slate-700' %>">
                                <% if(isAdmin) { %>
                                    <div class="absolute -top-10 left-12 md:left-16 flex gap-1 opacity-0 group-hover/autor:opacity-100 transition-opacity z-20 bg-white/80 dark:bg-slate-700/80 backdrop-blur-sm p-1 rounded-lg shadow border border-slate-200 dark:border-slate-600">
                                        <button class="btn-editar-depoimento bg-blue-600 hover:bg-blue-500 text-white px-2 py-1 rounded shadow text-[10px] font-bold" data-index="<%= index %>" data-campo="autor">Nome</button>
                                        <button class="btn-editar-depoimento bg-orange-500 hover:bg-orange-400 text-white px-2 py-1 rounded shadow text-[10px] font-bold" data-index="<%= index %>" data-campo="papel">Cargo</button>
                                    </div>
                                <% } %>
                                <div class="w-10 h-10 md:w-14 md:h-14 bg-gradient-to-br <%= isBlue ? 'from-brand-primary to-blue-400' : 'from-slate-200 to-slate-400' %> rounded-full flex-shrink-0"></div>
                                <div>
                                    <h4 id="texto-dep-<%= index %>-autor" class="font-bold <%= nameClass %> text-sm md:text-lg leading-tight"><%= dep.autor %></h4>
                                    <span id="texto-dep-<%= index %>-papel" class="text-[10px] md:text-xs <%= isBlue ? 'text-blue-300 dark:text-brand-accent' : 'text-brand-accent' %> font-bold uppercase tracking-wider"><%= dep.papel %></span>
                                </div>
                            </div>
                        </div>

                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</section>
<% } %>

<% const secFaqAtiva = siteData.config?.seccoesAtivas?.home_faq !== false; %>
<% if (secFaqAtiva || isAdmin) { %>
<section class="py-16 md:py-24 bg-slate-100 dark:bg-slate-900 transition-colors duration-500 border-t border-slate-200 dark:border-slate-800 relative w-full overflow-hidden <%= !secFaqAtiva ? 'opacity-60 grayscale border-y-4 border-dashed border-red-500' : '' %>">
    
    <% if(isAdmin) { %>
        <div class="absolute top-4 left-1/2 -translate-x-1/2 z-50">
            <button class="btn-toggle-seccao <%= secFaqAtiva ? 'bg-slate-700' : 'bg-red-600' %> text-white px-4 py-1.5 rounded-full text-xs font-bold shadow-lg whitespace-nowrap" data-seccao="home_faq">
                <%= secFaqAtiva ? '👁️ Ocultar Secção de Dúvidas' : '🚫 Secção Oculta (Ativar)' %>
            </button>
        </div>
    <% } %>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-6 w-full">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-12 hidden-scroll gap-4">
            <div class="relative group/faqtop w-full md:w-auto text-left">
                <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 right-0 md:-right-8 bg-brand-accent text-white p-1.5 md:p-2 rounded-full shadow z-50 opacity-0 group-hover/faqtop:opacity-100 text-[10px] md:text-xs" data-pagina="home" data-chave="faqTitulo">✏️</button><% } %>
                <h2 id="texto-home-faqTitulo" class="text-3xl md:text-5xl font-extrabold text-brand-blue dark:text-white leading-tight"><%= siteData.home.faqTitulo %></h2>
            </div>
            <% if(isAdmin) { %>
                <button id="btn-adicionar-faq" class="bg-green-500 hover:bg-green-400 text-white px-4 py-2 md:w-10 md:h-10 md:p-0 md:rounded-full rounded-lg flex items-center justify-center text-sm md:text-2xl font-bold md:font-black shadow-lg transition-all hover:scale-105 z-50 w-full md:w-auto shrink-0" title="Adicionar Nova Pergunta">
                    <span class="md:hidden mr-2">+ Adicionar Nova Pergunta</span><span class="hidden md:inline">+</span>
                </button>
            <% } %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 hidden-scroll delay-100 w-full">
            <% if(siteData.home.faqs && siteData.home.faqs.length > 0) { %>
                <% siteData.home.faqs.forEach((faq, index) => { %>
                    <div class="bg-white dark:bg-slate-800 p-5 md:p-6 rounded-xl md:rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 hover:-translate-y-1 transition-all relative group/faq w-full h-full flex flex-col justify-start">
                        <% if(isAdmin) { %>
                            <div class="absolute top-2 right-2 flex gap-1 z-50 opacity-0 group-hover/faq:opacity-100 transition-opacity flex-wrap justify-end">
                                <button class="btn-editar-faq bg-blue-500 hover:bg-blue-400 text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-index="<%= index %>" data-campo="pergunta">✏️ Perg</button>
                                <button class="btn-editar-faq bg-green-600 hover:bg-green-500 text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-index="<%= index %>" data-campo="resposta">✏️ Resp</button>
                                <button class="btn-remover-faq bg-red-600 hover:bg-red-500 text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-index="<%= index %>" title="Remover">🗑️</button>
                            </div>
                        <% } %>
                        <h3 class="text-base md:text-lg font-bold text-brand-blue dark:text-white mb-2 flex items-start gap-2">
                            <span class="mt-1 shrink-0">❓</span> 
                            <span id="texto-faq-<%= index %>-pergunta" class="block mt-1"><%= faq.pergunta %></span>
                        </h3>
                        <p id="texto-faq-<%= index %>-resposta" class="text-sm md:text-base text-slate-600 dark:text-slate-400 pl-6 md:pl-8 leading-relaxed"><%= faq.resposta %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-center text-slate-500 italic col-span-full">Nenhuma pergunta cadastrada.</p>
            <% } %>
        </div>
    </div>
</section>
<% } %>

<% const secCtaAtiva = siteData.config?.seccoesAtivas?.home_cta !== false; %>
<% if (secCtaAtiva || isAdmin) { %>
<section class="hidden-scroll py-20 md:py-32 bg-grad-animated bg-[length:200%_auto] animate-shimmer relative overflow-hidden shadow-[inset_0_20px_50px_rgba(0,0,0,0.1)] w-full <%= !secCtaAtiva ? 'opacity-60 grayscale border-y-4 border-dashed border-red-500' : '' %>">
    
    <% if(isAdmin) { %>
        <div class="absolute top-4 left-1/2 -translate-x-1/2 z-50">
            <button class="btn-toggle-seccao <%= secCtaAtiva ? 'bg-slate-700' : 'bg-red-600' %> text-white px-4 py-1.5 rounded-full text-xs font-bold shadow-lg border border-white/20 whitespace-nowrap" data-seccao="home_cta">
                <%= secCtaAtiva ? '👁️ Ocultar Chamada Final' : '🚫 Secção Oculta (Ativar)' %>
            </button>
        </div>
    <% } %>

    <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiLz48L3N2Zz4=')] w-full"></div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10 group/cta mt-6 w-full">
        <% if(isAdmin) { %>
            <div class="absolute -top-12 right-0 md:right-1/4 flex flex-wrap justify-center gap-1 z-50 opacity-0 group-hover/cta:opacity-100 transition-opacity w-full md:w-auto">
                <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-pagina="home" data-chave="ctaTitulo">Tít</button>
                <button class="btn-editar-cms bg-green-500 text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-pagina="home" data-chave="ctaTexto">Txt</button>
                <button class="btn-editar-cms bg-brand-primary text-white px-2 py-1 rounded shadow text-[10px] md:text-xs font-bold" data-pagina="home" data-chave="ctaBtn">Botão</button>
            </div>
        <% } %>
        <h2 id="texto-home-ctaTitulo" class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white mb-6 md:mb-8 drop-shadow-lg leading-tight"><%= siteData.home.ctaTitulo %></h2>
        <p id="texto-home-ctaTexto" class="text-lg md:text-2xl text-orange-100 mb-8 md:mb-12 font-medium drop-shadow-md leading-relaxed px-2"><%= siteData.home.ctaTexto %></p>
        <a href="/doacoes" class="nav-link block sm:inline-block bg-white text-brand-accent px-8 md:px-12 py-4 md:py-5 rounded-full text-lg md:text-2xl font-black hover:bg-slate-50 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] hover:-translate-y-1 md:hover:-translate-y-2 transition-all duration-300 w-full sm:w-auto">
            <span id="texto-home-ctaBtn"><%= siteData.home.ctaBtn %></span>
        </a>
    </div>
</section>
<% } %>
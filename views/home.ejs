        <a href="/doacoes" class="nav-link inline-block bg-white text-brand-accent px-12 py-5 rounded-full text-2xl font-black hover:bg-slate-50 hover:scale-110 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] hover:-translate-y-2 transition-all duration-300">
            <span id="texto-home-ctaBtn"><%= siteData.home.ctaBtn %></span>

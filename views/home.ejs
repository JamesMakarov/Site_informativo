        <div class="relative group/sub w-full max-w-3xl mx-auto">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-8 bg-brand-accent text-white p-2 rounded-full shadow-xl opacity-0 group-hover/sub:opacity-100 transition-opacity z-50 text-xs" data-pagina="home" data-chave="heroSubtitulo">✏️</button><% } %>
            <p id="texto-home-heroSubtitulo" class="text-xl md:text-2xl mb-12 text-blue-100 drop-shadow-md leading-relaxed hidden-scroll delay-100"><%= siteData.home.heroSubtitulo %></p>
        </div>
        
        <div class="relative group/btn inline-block">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-4 bg-brand-accent text-white p-2 rounded-full shadow-xl opacity-0 group-hover/btn:opacity-100 transition-opacity z-50 text-xs" data-pagina="home" data-chave="heroBtn">✏️</button><% } %>

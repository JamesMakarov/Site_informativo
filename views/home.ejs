            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-10 bg-brand-accent text-white p-2 rounded-full shadow-xl opacity-0 group-hover/badge:opacity-100 transition-opacity z-50 text-xs" data-pagina="home" data-chave="heroBadge">✏️</button><% } %>

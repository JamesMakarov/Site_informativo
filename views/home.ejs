<div id="bg-home-heroBg" class="relative group bg-brand-blue flex items-center justify-center min-h-[90vh] text-white overflow-hidden bg-fixed bg-center bg-cover transition-all duration-700" style="background-image: url('<%= siteData.home.heroBg || '/img/noticia1.jpg' %>');">
    
    <% if(isAdmin) { %>
        <button class="absolute top-24 left-6 bg-brand-accent text-white px-4 py-2 rounded-full shadow-2xl opacity-0 group-hover:opacity-100 transition-opacity z-50 text-sm font-bold hover:scale-105 flex items-center gap-2 border-2 border-white/20" data-pagina="home" data-chave="heroBg" data-tipo="imagem">
            🖼️ Alterar Fundo
        </button>

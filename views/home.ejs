        <div class="hidden-scroll delay-300 group/stat relative bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-3xl p-8 text-center shadow-xl border border-transparent dark:border-slate-700 hover:border-brand-primary dark:hover:border-brand-accent hover:-translate-y-3 transition-all duration-500">
            <% if(isAdmin) { %>

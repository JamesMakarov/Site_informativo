<section class="relative pt-32 pb-24 bg-brand-blue dark:bg-slate-950 transition-colors duration-500 overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiLz48L3N2Zz4=')]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-brand-primary rounded-full blur-[120px] opacity-40 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        
        <% if(isAdmin) { %>
            <div class="flex justify-center gap-2 mb-6 bg-blue-900/50 dark:bg-slate-800/50 py-2 px-4 rounded-xl w-max mx-auto border border-blue-500/30">
                <button class="btn-editar-cms bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded text-xs font-bold transition-colors" data-pagina="galeria" data-chave="heroTitulo">✏️ Título</button>
                <button class="btn-editar-cms bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded text-xs font-bold transition-colors" data-pagina="galeria" data-chave="heroSubtitulo">✏️ Subtítulo</button>
                
                <button class="btn-adicionar-foto-direto bg-brand-accent hover:bg-orange-500 text-white px-4 py-1.5 rounded font-black text-xs transition-colors ml-2 shadow-lg flex items-center gap-2" data-pagina="galeria" data-lista="fotos">
                    <span class="text-lg">+</span> Adicionar Fotografia
                </button>
            </div>
        <% } %>

        <h1 id="texto-galeria-heroTitulo" class="hidden-scroll text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-6 drop-shadow-lg"><%= siteData.galeria.heroTitulo %></h1>
        <p id="texto-galeria-heroSubtitulo" class="hidden-scroll delay-100 text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed"><%= siteData.galeria.heroSubtitulo %></p>
    </div>
</section>

<section class="py-16 bg-slate-50 dark:bg-slate-900 transition-colors duration-500 min-h-[50vh]">
    <div class="max-w-[90rem] mx-auto px-6">
        
        <div class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-6 space-y-6">
            <% siteData.galeria.fotos.forEach((foto, index) => { %>
                
                <div class="hidden-scroll break-inside-avoid relative group rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-800">
                    
                    <div class="img-galeria cursor-zoom-in relative">
                        <img id="img-fotos-<%= index %>" src="<%= foto.imagem %>" onerror="this.src='https://via.placeholder.com/600x800?text=Foto'" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700">
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6 pointer-events-none">
                            <p id="texto-fotos-<%= index %>-titulo" class="text-white font-bold text-lg drop-shadow-md leading-tight"><%= foto.titulo %></p>
                        </div>
                    </div>

                    <% if(isAdmin) { %>
                        <div class="bg-white dark:bg-slate-800 p-3 border-t border-slate-100 dark:border-slate-700 flex flex-wrap gap-1 justify-between items-center z-20 relative">
                            <div class="flex gap-1">
                                <button class="btn-editar-lista bg-brand-accent text-white px-2 py-1 rounded text-[10px] font-bold" data-pagina="galeria" data-lista="fotos" data-index="<%= index %>" data-campo="imagem" data-tipo="imagem">🖼️ Trocar</button>
                                <button class="btn-editar-lista bg-blue-500 text-white px-2 py-1 rounded text-[10px] font-bold" data-pagina="galeria" data-lista="fotos" data-index="<%= index %>" data-campo="titulo">Tít</button>
                            </div>
                            <button class="btn-remover-lista text-red-500 hover:bg-red-500 hover:text-white px-2 py-1 rounded text-[10px] font-bold border border-red-200 hover:border-transparent transition-colors" data-pagina="galeria" data-lista="fotos" data-index="<%= index %>">Apagar</button>
                        </div>
                    <% } %>

                </div>

            <% }) %>
        </div>

    </div>
</section>

<div id="lightbox-galeria" class="fixed inset-0 bg-black/95 z-[100] hidden items-center justify-center p-4 backdrop-blur-md transition-opacity">
    <span id="fechar-lightbox" class="absolute top-6 right-8 text-white/70 text-5xl font-bold cursor-pointer hover:text-brand-accent transition-colors z-50">&times;</span>
    
    <button id="lightbox-prev" class="absolute left-2 md:left-10 text-white/50 hover:text-white text-4xl md:text-6xl z-50 p-4 transition-colors">❮</button>
    
    <div class="relative max-w-[85vw] max-h-[85vh] flex flex-col items-center">
        <img id="lightbox-img" src="" class="max-w-full max-h-[80vh] rounded-lg shadow-[0_0_50px_rgba(0,0,0,0.5)] object-contain select-none transition-opacity duration-300">
        <p id="lightbox-caption" class="text-white/80 font-medium text-lg mt-4 text-center"></p>
    </div>
    
    <button id="lightbox-next" class="absolute right-2 md:right-10 text-white/50 hover:text-white text-4xl md:text-6xl z-50 p-4 transition-colors">❯</button>
</div>
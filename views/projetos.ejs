<section class="relative pt-32 pb-20 bg-brand-blue dark:bg-slate-950 overflow-hidden transition-colors duration-500 min-h-[50vh] flex items-center">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#FF6B0B_1px,transparent_1px)] [background-size:30px_30px]"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-primary rounded-full blur-[120px] opacity-40 animate-blob pointer-events-none"></div>
    <div class="absolute top-10 right-10 w-72 h-72 bg-brand-accent rounded-full blur-[100px] opacity-20 animate-blob-delayed pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 relative z-10 text-center group">
        
        <div class="relative inline-block w-full group/badge">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-8 bg-brand-accent text-white px-2 py-1 rounded shadow opacity-0 group-hover/badge:opacity-100 text-xs z-50" data-pagina="projetos" data-chave="heroBadge">✏️</button><% } %>
            <span id="texto-projetos-heroBadge" class="hidden-scroll inline-block py-1 px-4 rounded-full bg-blue-500/20 text-blue-300 border border-blue-400/30 font-black tracking-[0.2em] text-sm mb-6"><%= siteData.projetos.heroBadge %></span>
        </div>

        <div class="relative w-full group/titulo">
            <% if(isAdmin) { %>
                <div class="absolute -top-6 -right-4 flex gap-1 z-50 opacity-0 group-hover/titulo:opacity-100">
                    <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="heroTitulo">✏️ Título</button>
                    <button class="btn-editar-cms bg-orange-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="heroTituloDestaque">✏️ Destaque</button>
                </div>
            <% } %>
            <h1 class="hidden-scroll delay-100 text-5xl md:text-7xl font-extrabold text-white mb-8 tracking-tight drop-shadow-2xl">
                <span id="texto-projetos-heroTitulo"><%= siteData.projetos.heroTitulo %></span> 
                <span id="texto-projetos-heroTituloDestaque" class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-brand-accent"><%= siteData.projetos.heroTituloDestaque %></span>
            </h1>
        </div>
        
        <div class="relative w-full max-w-4xl mx-auto group/sub">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 -right-8 bg-brand-accent text-white px-2 py-1 rounded shadow opacity-0 group-hover/sub:opacity-100 text-xs z-50" data-pagina="projetos" data-chave="heroSubtitulo">✏️</button><% } %>
            <p id="texto-projetos-heroSubtitulo" class="hidden-scroll delay-200 text-xl md:text-2xl text-blue-100 leading-relaxed drop-shadow-md">
                <%= siteData.projetos.heroSubtitulo %>
            </p>
        </div>
    </div>
</section>

<section class="py-24 bg-slate-50 dark:bg-slate-900 transition-colors duration-500 relative z-20 -mt-10 rounded-t-[3rem] shadow-[0_-20px_50px_rgba(0,0,0,0.1)]">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-20 relative group inline-block w-full">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 right-1/4 bg-brand-accent text-white px-2 py-1 rounded shadow opacity-0 group-hover:opacity-100 text-xs z-50" data-pagina="projetos" data-chave="pilaresTitulo">✏️</button><% } %>
            <h2 id="texto-projetos-pilaresTitulo" class="hidden-scroll text-4xl md:text-5xl font-extrabold text-brand-blue dark:text-white mb-6"><%= siteData.projetos.pilaresTitulo %></h2>
            <div class="hidden-scroll delay-100 w-24 h-1 bg-brand-primary mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <% siteData.projetos.pilares.forEach((pilar, index) => { %>
                <div class="hidden-scroll delay-<%= (index+1)*100 %> group relative bg-white dark:bg-slate-800 rounded-3xl p-10 shadow-xl border border-gray-100 dark:border-slate-700 hover:shadow-2xl hover:-translate-y-4 transition-all duration-500 overflow-hidden group/card">
                    
                    <% if(isAdmin) { %>
                        <div class="absolute top-2 right-2 flex gap-1 z-50 opacity-0 group-hover/card:opacity-100 transition-opacity">
                            <button class="btn-editar-lista bg-brand-accent text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="pilares" data-index="<%= index %>" data-campo="icone">Ícone</button>
                            <button class="btn-editar-lista bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="pilares" data-index="<%= index %>" data-campo="titulo">Título</button>
                            <button class="btn-editar-lista bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="pilares" data-index="<%= index %>" data-campo="texto">Texto</button>
                        </div>
                    <% } %>

                    <div class="absolute top-0 right-0 w-32 h-32 bg-<%= pilar.cor %>-50 dark:bg-slate-700 rounded-bl-full -mr-16 -mt-16 transition-transform group-hover:scale-150 duration-700"></div>
                    <div id="texto-pilares-<%= index %>-icone" class="text-6xl mb-8 relative z-10 transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-500"><%= pilar.icone %></div>
                    <h3 id="texto-pilares-<%= index %>-titulo" class="text-2xl font-bold text-brand-blue dark:text-white mb-4 relative z-10"><%= pilar.titulo %></h3>
                    <p id="texto-pilares-<%= index %>-texto" class="text-slate-600 dark:text-slate-300 leading-relaxed mb-6 relative z-10"><%= pilar.texto %></p>
                    <div class="w-12 h-1 bg-brand-primary rounded-full group-hover:w-full transition-all duration-500 relative z-10"></div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<section class="py-24 bg-white dark:bg-slate-950 transition-colors duration-500">
    <div class="max-w-7xl mx-auto px-6">
        <div class="hidden-scroll bg-grad-dark dark:bg-none dark:bg-slate-900 rounded-[3rem] p-8 md:p-16 shadow-2xl relative overflow-hidden border border-slate-800">
            <div class="absolute inset-0 opacity-30 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiLz48L3N2Zz4=')]"></div>
            
            <div class="relative z-10 flex flex-col lg:flex-row gap-12 items-center">
                <div class="lg:w-1/2 w-full">
                    <div class="relative group rounded-3xl overflow-hidden shadow-2xl border-4 border-slate-700 group/img">
                        <img src="/img/noticia2.jpg" onerror="this.src='https://via.placeholder.com/800x600?text=Robótica+e+Educação'" alt="Centro Educacional" class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-transparent to-transparent opacity-80"></div>
                        <div class="absolute bottom-6 left-6 relative w-max">
                            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-8 left-0 bg-brand-accent text-white px-2 py-1 rounded shadow opacity-0 group-hover/img:opacity-100 text-xs z-50" data-pagina="projetos" data-chave="destaqueBadge">✏️</button><% } %>
                            <span id="texto-projetos-destaqueBadge" class="bg-brand-accent text-white font-bold px-4 py-2 rounded-full text-xs uppercase tracking-wider shadow-lg"><%= siteData.projetos.destaqueBadge %></span>
                        </div>
                    </div>
                </div>
                
                <div class="lg:w-1/2 w-full text-white relative group/text">
                    <% if(isAdmin) { %>
                        <div class="absolute top-0 right-0 flex gap-1 z-50 opacity-0 group-hover/text:opacity-100 flex-col">
                            <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="destaqueLocal">📍 Local</button>
                            <button class="btn-editar-cms bg-orange-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="destaqueTitulo">Título</button>
                            <button class="btn-editar-cms bg-brand-primary text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="destaqueTituloDestaque">Destaque</button>
                            <button class="btn-editar-cms bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold mt-2" data-pagina="projetos" data-chave="destaqueTexto1">Txt 1</button>
                            <button class="btn-editar-cms bg-green-600 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="destaqueTexto2">Txt 2</button>
                        </div>
                    <% } %>

                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-brand-accent text-2xl">📍</span>
                        <h4 id="texto-projetos-destaqueLocal" class="text-blue-300 font-bold tracking-widest text-sm uppercase"><%= siteData.projetos.destaqueLocal %></h4>
                    </div>
                    <h3 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
                        <span id="texto-projetos-destaqueTitulo"><%= siteData.projetos.destaqueTitulo %></span> 
                        <span id="texto-projetos-destaqueTituloDestaque" class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-brand-accent"><%= siteData.projetos.destaqueTituloDestaque %></span>
                    </h3>
                    <p id="texto-projetos-destaqueTexto1" class="text-lg text-slate-300 mb-6 leading-relaxed"><%= siteData.projetos.destaqueTexto1 %></p>
                    <p id="texto-projetos-destaqueTexto2" class="text-lg text-slate-300 mb-8 leading-relaxed"><%= siteData.projetos.destaqueTexto2 %></p>
                    
                    <div class="flex gap-4">
                        <div class="bg-white/10 backdrop-blur-md px-6 py-3 rounded-xl border border-white/20 text-center flex-1 relative group/stat1">
                            <% if(isAdmin) { %><button class="btn-editar-cms absolute top-0 right-0 bg-blue-500 text-white px-1 py-1 rounded opacity-0 group-hover/stat1:opacity-100 text-[10px]" data-pagina="projetos" data-chave="destaqueStat1Num">✏️</button><% } %>
                            <h5 id="texto-projetos-destaqueStat1Num" class="text-3xl font-black text-brand-accent"><%= siteData.projetos.destaqueStat1Num %></h5>
                            <span id="texto-projetos-destaqueStat1Txt" class="text-xs text-slate-400 uppercase font-bold"><%= siteData.projetos.destaqueStat1Txt %></span>
                        </div>
                        <div class="bg-white/10 backdrop-blur-md px-6 py-3 rounded-xl border border-white/20 text-center flex-1 relative group/stat2">
                            <% if(isAdmin) { %><button class="btn-editar-cms absolute top-0 right-0 bg-blue-500 text-white px-1 py-1 rounded opacity-0 group-hover/stat2:opacity-100 text-[10px]" data-pagina="projetos" data-chave="destaqueStat2Num">✏️</button><% } %>
                            <h5 id="texto-projetos-destaqueStat2Num" class="text-3xl font-black text-brand-primary"><%= siteData.projetos.destaqueStat2Num %></h5>
                            <span id="texto-projetos-destaqueStat2Txt" class="text-xs text-slate-400 uppercase font-bold"><%= siteData.projetos.destaqueStat2Txt %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-24 bg-slate-100 dark:bg-slate-900 transition-colors duration-500">
    <div class="max-w-7xl mx-auto px-6">
        <div class="relative group inline-block w-full text-center">
            <% if(isAdmin) { %><button class="btn-editar-cms absolute -top-4 right-1/4 bg-brand-accent text-white px-2 py-1 rounded shadow opacity-0 group-hover:opacity-100 text-xs z-50" data-pagina="projetos" data-chave="outrosTitulo">✏️</button><% } %>
            <h2 id="texto-projetos-outrosTitulo" class="hidden-scroll text-3xl font-extrabold text-brand-blue dark:text-white mb-16"><%= siteData.projetos.outrosTitulo %></h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <% siteData.projetos.outros.forEach((outro, index) => { %>
                <div class="hidden-scroll delay-<%= index * 100 %> relative bg-white dark:bg-slate-800 rounded-3xl p-8 shadow-md flex items-start gap-6 border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-shadow group/card">
                    <% if(isAdmin) { %>
                        <div class="absolute top-2 right-2 flex gap-1 z-50 opacity-0 group-hover/card:opacity-100 transition-opacity">
                            <button class="btn-editar-lista bg-brand-accent text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="outros" data-index="<%= index %>" data-campo="icone">Ícone</button>
                            <button class="btn-editar-lista bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="outros" data-index="<%= index %>" data-campo="titulo">Título</button>
                            <button class="btn-editar-lista bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-lista="outros" data-index="<%= index %>" data-campo="texto">Texto</button>
                        </div>
                    <% } %>
                    <div id="texto-outros-<%= index %>-icone" class="w-20 h-20 bg-<%= outro.corClass %>/10 dark:bg-<%= outro.corClass %>/20 rounded-2xl flex items-center justify-center text-4xl flex-shrink-0 text-<%= outro.corClass %>"><%= outro.icone %></div>
                    <div>
                        <h4 id="texto-outros-<%= index %>-titulo" class="text-xl font-bold text-brand-blue dark:text-white mb-2"><%= outro.titulo %></h4>
                        <p id="texto-outros-<%= index %>-texto" class="text-slate-600 dark:text-slate-400 leading-relaxed"><%= outro.texto %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<section class="py-24 bg-white dark:bg-slate-950 transition-colors duration-500">
    <div class="max-w-4xl mx-auto px-6 text-center group/cta relative">
        <% if(isAdmin) { %>
            <div class="absolute top-0 right-0 flex gap-1 z-50 opacity-0 group-hover/cta:opacity-100 transition-opacity">
                <button class="btn-editar-cms bg-blue-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="ctaTitulo">Título</button>
                <button class="btn-editar-cms bg-green-500 text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="ctaTexto">Texto</button>
                <button class="btn-editar-cms bg-brand-primary text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="ctaBtn1">Btn 1</button>
                <button class="btn-editar-cms bg-brand-accent text-white px-2 py-1 rounded shadow text-xs font-bold" data-pagina="projetos" data-chave="ctaBtn2">Btn 2</button>
            </div>
        <% } %>
        
        <div class="hidden-scroll inline-flex items-center justify-center w-24 h-24 bg-blue-50 dark:bg-slate-800 rounded-full mb-8 shadow-inner"><span class="text-5xl">🤝</span></div>
        <h2 id="texto-projetos-ctaTitulo" class="hidden-scroll delay-100 text-4xl md:text-5xl font-extrabold text-brand-blue dark:text-white mb-6"><%= siteData.projetos.ctaTitulo %></h2>
        <p id="texto-projetos-ctaTexto" class="hidden-scroll delay-200 text-xl text-slate-600 dark:text-slate-400 mb-10 leading-relaxed"><%= siteData.projetos.ctaTexto %></p>
        
        <div class="hidden-scroll delay-300 flex flex-col sm:flex-row justify-center gap-6">
            <a href="/doacoes" class="nav-link bg-brand-primary text-white hover:bg-blue-800 px-10 py-4 rounded-full text-xl font-bold shadow-lg hover:-translate-y-2 transition-all duration-300 text-center"><span id="texto-projetos-ctaBtn1"><%= siteData.projetos.ctaBtn1 %></span></a>
            <a href="/oracao" class="nav-link bg-white dark:bg-slate-800 border-2 border-brand-accent text-brand-accent hover:bg-brand-accent hover:text-white px-10 py-4 rounded-full text-xl font-bold shadow-lg hover:-translate-y-2 transition-all duration-300 text-center"><span id="texto-projetos-ctaBtn2"><%= siteData.projetos.ctaBtn2 %></span></a>
        </div>
    </div>
</section>
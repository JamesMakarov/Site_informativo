<section class="relative pt-32 pb-24 bg-slate-50 dark:bg-slate-950 transition-colors duration-500 overflow-hidden border-b border-gray-200 dark:border-slate-800">
    <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.05] bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiMwMDAiLz48L3N2Zz4=')] dark:bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiLz48L3N2Zz4=')]"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">

        <div class="text-center mb-12 w-full">
            <% if(isAdmin) { %>
                <div class="flex justify-center gap-2 mb-6 bg-blue-100/50 dark:bg-slate-800/50 py-2 px-4 rounded-xl w-max mx-auto border border-blue-200 dark:border-slate-700">
                    <span class="text-xs font-bold text-slate-500 uppercase flex items-center mr-2">Editar Cabeçalho:</span>
                    <button class="btn-editar-cms bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="heroTitulo1">✏️ Título</button>
                    <button class="btn-editar-cms bg-brand-primary hover:bg-blue-700 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="heroTituloDestaque">✏️ Destaque</button>
                    <button class="btn-editar-cms bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="heroSubtitulo">✏️ Subtítulo</button>
                </div>
            <% } %>

            <h1 class="hidden-scroll text-5xl md:text-7xl font-extrabold text-brand-blue dark:text-white tracking-tight mb-4">
                <span id="texto-noticias-heroTitulo1"><%= siteData.noticias.heroTitulo1 %></span>
                <span id="texto-noticias-heroTituloDestaque" class="text-transparent bg-clip-text bg-grad-primary"><%= siteData.noticias.heroTituloDestaque %></span>
            </h1>
            <p id="texto-noticias-heroSubtitulo" class="hidden-scroll delay-100 text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto"><%= siteData.noticias.heroSubtitulo %></p>
        </div>

        <% const page = locals.currentPage || 1; %>
        
        <% if(page === 1 && siteData.noticias.feedList && siteData.noticias.feedList.length > 0) { %>
            <% const dest = siteData.noticias.feedList[0]; const destIdx = 0; %>

            <div class="hidden-scroll delay-200 relative bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100 dark:border-slate-800 cursor-pointer hover:shadow-brand-primary/10 transition-all" onclick="if(!event.target.closest('button')) window.location.href='/noticia/<%= dest.id %>'">
                <div class="flex flex-col lg:flex-row">

                    <div class="lg:w-3/5 overflow-hidden relative">
                        <% if(dest.isEmoji || !dest.imagem) { %>
                            <div class="w-full h-full bg-gradient-to-br from-blue-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center min-h-[400px] hover:scale-105 transition-transform duration-1000">
                                <span id="texto-feedList-<%= destIdx %>-emoji" class="text-9xl opacity-50"><%= dest.emoji || "📰" %></span>
                            </div>
                        <% } else { %>
                            <img id="img-feedList-<%= destIdx %>" src="<%= dest.imagem %>" onerror="this.src='https://via.placeholder.com/1000x600?text=Sem+Imagem'" alt="Destaque" class="w-full h-full object-cover min-h-[400px] hover:scale-105 transition-transform duration-1000">
                        <% } %>

                        <% if(isAdmin) { %>
                            <button class="absolute top-4 right-4 bg-brand-accent/90 backdrop-blur-md hover:bg-brand-accent text-white px-4 py-2 rounded-full shadow-xl z-50 text-sm font-bold flex items-center gap-2 border border-white/20 transition-colors" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>" data-campo="imagem" data-tipo="imagem">🖼️ Mudar Foto</button>
                        <% } %>

                        <div class="absolute top-6 left-6 z-20">
                            <span id="texto-feedList-<%= destIdx %>-badge" class="bg-<%= dest.badgeCor || 'brand-primary' %> text-white font-black px-4 py-1.5 rounded-full text-xs uppercase tracking-widest shadow-lg animate-pulse"><%= dest.badge %></span>
                        </div>
                    </div>

                    <div class="lg:w-2/5 p-10 md:p-14 flex flex-col justify-center relative">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-primary/5 dark:bg-brand-primary/10 rounded-bl-full -mr-10 -mt-10 pointer-events-none"></div>

                        <% if(isAdmin) { %>
                            <div class="flex flex-wrap gap-2 mb-8 bg-slate-50 dark:bg-slate-800/80 p-3 rounded-xl border border-slate-200 dark:border-slate-700 relative z-30">
                                <span class="w-full text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Editar Reportagem de Destaque</span>
                                <button class="btn-editar-lista bg-blue-500 hover:bg-blue-600 text-white px-2 py-1 rounded text-xs font-bold" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>" data-campo="badge">Badge</button>
                                <button class="btn-editar-lista bg-orange-500 hover:bg-orange-600 text-white px-2 py-1 rounded text-xs font-bold" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>" data-campo="data">Data</button>
                                <button class="btn-editar-lista bg-green-500 hover:bg-green-600 text-white px-2 py-1 rounded text-xs font-bold" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>" data-campo="titulo">Tít</button>
                                <button class="btn-editar-lista bg-purple-500 hover:bg-purple-600 text-white px-2 py-1 rounded text-xs font-bold" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>" data-campo="texto">Txt</button>
                                <button class="btn-remover-lista bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded text-xs font-bold ml-auto" data-pagina="noticias" data-lista="feedList" data-index="<%= destIdx %>">🗑️ Apagar</button>
                            </div>
                        <% } %>

                        <div class="flex items-center gap-3 mb-6 text-sm font-bold text-brand-accent">
                            <span id="texto-feedList-<%= destIdx %>-data"><%= dest.data %></span>
                            <span class="text-slate-300 dark:text-slate-700">|</span>
                            <span class="uppercase tracking-wider">DESTAQUE PRINCIPAL</span>
                        </div>

                        <h2 id="texto-feedList-<%= destIdx %>-titulo" class="text-3xl md:text-5xl font-extrabold text-brand-blue dark:text-white mb-6 leading-tight group-hover:text-brand-primary dark:group-hover:text-brand-accent transition-colors duration-300 line-clamp-3">
                            <%= dest.titulo %>
                        </h2>

                        <p id="texto-feedList-<%= destIdx %>-texto" class="text-lg text-slate-600 dark:text-slate-400 mb-8 leading-relaxed line-clamp-4">
                            <%= dest.texto %>
                        </p>

                        <a href="/noticia/<%= dest.id %>" class="inline-flex items-center gap-3 text-brand-primary dark:text-brand-accent font-bold text-lg hover:gap-5 transition-all mt-auto">Ler reportagem <span class="text-2xl">→</span></a>
                    </div>
                </div>
            </div>
        <% } else if(page === 1) { %>
            <p class="text-center text-slate-500 italic mt-8 bg-white dark:bg-slate-900 py-12 rounded-[2rem] shadow-sm border border-slate-100 dark:border-slate-800">Nenhuma notícia encontrada no momento.</p>
        <% } %>
    </div>
</section>

<% 
    const limit = 6; 
    const totalNoticias = Math.max(0, (siteData.noticias.feedList || []).length - 1); 
    const totalPages = Math.ceil(totalNoticias / limit) || 1;
    const startIndex = 1 + ((page - 1) * limit);
    const endIndex = startIndex + limit;
    const noticiasPagina = (siteData.noticias.feedList || []).slice(startIndex, endIndex);
%>

<section class="py-24 bg-white dark:bg-slate-900 transition-colors duration-500 relative">
    <div class="max-w-7xl mx-auto px-6">

        <div class="flex flex-col mb-16 border-b border-slate-200 dark:border-slate-800 pb-6">
            
            <% if(isAdmin) { %>
                <div class="w-full flex flex-wrap items-center justify-between gap-4 bg-slate-100/50 dark:bg-slate-800/50 p-4 rounded-xl border border-slate-200 dark:border-slate-700 mb-8">
                    <div class="flex gap-2 items-center">
                        <span class="text-xs font-bold text-slate-500 uppercase mr-2">Filtros:</span>
                        <button class="btn-editar-cms bg-slate-500 hover:bg-slate-600 text-white px-3 py-1.5 rounded text-xs font-bold" data-pagina="noticias" data-chave="feedFiltro1">Filtro 1</button>
                        <button class="btn-editar-cms bg-slate-500 hover:bg-slate-600 text-white px-3 py-1.5 rounded text-xs font-bold" data-pagina="noticias" data-chave="feedFiltro2">Filtro 2</button>
                        <button class="btn-editar-cms bg-slate-500 hover:bg-slate-600 text-white px-3 py-1.5 rounded text-xs font-bold" data-pagina="noticias" data-chave="feedFiltro3">Filtro 3</button>
                    </div>
                    <button id="btn-criar-noticia" class="bg-green-500 hover:bg-green-400 text-white px-5 py-2 rounded-full text-sm font-bold shadow-lg transition-transform hover:-translate-y-1 flex items-center gap-2">
                        <span class="text-lg">+</span> Publicar Nova Reportagem
                    </button>
                </div>
            <% } %>

            <div class="flex flex-col md:flex-row justify-between items-end w-full">
                <div class="w-full md:w-auto mb-6 md:mb-0">
                    <% if(isAdmin && page === 1) { %>
                        <button class="btn-editar-cms bg-blue-500 hover:bg-blue-600 text-white px-2 py-1 rounded shadow text-xs font-bold mb-2 block" data-pagina="noticias" data-chave="feedTitulo">✏️ Mudar Título Secção</button>
                    <% } %>
                    <h3 id="texto-noticias-feedTitulo" class="hidden-scroll text-3xl md:text-4xl font-extrabold text-brand-blue dark:text-white"><%= page === 1 ? siteData.noticias.feedTitulo : `Página ${page}` %></h3>
                </div>
                
                <div class="hidden-scroll delay-100 flex flex-wrap gap-2">
                    <span id="texto-noticias-feedFiltro1" class="bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-4 py-2 rounded-full text-sm font-bold cursor-pointer hover:bg-brand-primary hover:text-white transition-colors"><%= siteData.noticias.feedFiltro1 %></span>
                    <span id="texto-noticias-feedFiltro2" class="bg-transparent border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 px-4 py-2 rounded-full text-sm font-bold cursor-pointer hover:border-brand-primary dark:hover:border-brand-accent transition-colors"><%= siteData.noticias.feedFiltro2 %></span>
                    <span id="texto-noticias-feedFiltro3" class="bg-transparent border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 px-4 py-2 rounded-full text-sm font-bold cursor-pointer hover:border-brand-primary dark:hover:border-brand-accent transition-colors"><%= siteData.noticias.feedFiltro3 %></span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <% noticiasPagina.forEach((noticia, localI) => { %>
                <% const realIndex = startIndex + localI; %> 

                <div class="hidden-scroll delay-<%= localI * 100 %> group flex flex-col h-full bg-white dark:bg-slate-900 rounded-3xl overflow-hidden border border-slate-100 dark:border-slate-800 shadow-sm hover:shadow-xl transition-shadow cursor-pointer" onclick="if(!event.target.closest('button')) window.location.href='/noticia/<%= noticia.id %>'">

                    <div class="relative overflow-hidden aspect-video">
                        <% if(noticia.isEmoji || !noticia.imagem) { %>
                            <div class="w-full h-full bg-gradient-to-br from-blue-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center group-hover:scale-110 transition-transform duration-700">
                                <span id="texto-feedList-<%= realIndex %>-emoji" class="text-7xl opacity-50"><%= noticia.emoji || "📰" %></span>
                            </div>
                        <% } else { %>
                            <img id="img-feedList-<%= realIndex %>" src="<%= noticia.imagem %>" onerror="this.src='/img/noticia1.jpg'" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <% } %>
                        
                        <% if(isAdmin) { %>
                            <button class="absolute top-3 right-3 bg-brand-accent/90 hover:bg-brand-accent text-white p-2 rounded-full shadow-lg z-20 text-[10px] font-bold transition-colors border border-white/20" data-pagina="noticias" data-lista="feedList" data-index="<%= realIndex %>" data-campo="imagem" data-tipo="imagem" title="Mudar Capa">🖼️</button>
                        <% } %>

                        <div class="absolute top-4 left-4 pointer-events-none">
                            <span id="texto-feedList-<%= realIndex %>-badge" class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-sm text-<%= noticia.badgeCor || 'brand-primary' %> font-bold px-3 py-1 rounded-lg text-xs uppercase tracking-wider shadow-sm"><%= noticia.badge %></span>
                        </div>
                    </div>

                    <div class="p-8 flex-1 flex flex-col">
                        <span id="texto-feedList-<%= realIndex %>-data" class="text-brand-accent text-sm font-bold mb-3"><%= noticia.data %></span>
                        <h4 id="texto-feedList-<%= realIndex %>-titulo" class="text-2xl font-bold text-brand-blue dark:text-white mb-3 group-hover:text-brand-primary transition-colors line-clamp-2"><%= noticia.titulo %></h4>
                        <p id="texto-feedList-<%= realIndex %>-texto" class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3 leading-relaxed"><%= noticia.texto %></p>
                        <span class="mt-auto font-bold text-slate-400 group-hover:text-brand-accent transition-colors flex items-center gap-2">Ler mais <span class="group-hover:translate-x-2 transition-transform">→</span></span>
                    </div>

                    <% if(isAdmin) { %>
                        <div class="bg-slate-50 dark:bg-slate-800/60 p-4 border-t border-slate-200 dark:border-slate-700 flex flex-wrap gap-2 justify-between items-center relative z-20">
                            <div class="flex gap-1">
                                <button class="btn-editar-lista bg-blue-500 hover:bg-blue-600 text-white px-2 py-1 rounded text-[10px] font-bold transition-colors" data-pagina="noticias" data-lista="feedList" data-index="<%= realIndex %>" data-campo="badge">Badge</button>
                                <button class="btn-editar-lista bg-orange-500 hover:bg-orange-600 text-white px-2 py-1 rounded text-[10px] font-bold transition-colors" data-pagina="noticias" data-lista="feedList" data-index="<%= realIndex %>" data-campo="data">Data</button>
                                <button class="btn-editar-lista bg-green-600 hover:bg-green-700 text-white px-2 py-1 rounded text-[10px] font-bold transition-colors" data-pagina="noticias" data-lista="feedList" data-index="<%= realIndex %>" data-campo="titulo">Tít</button>
                            </div>
                            <button class="btn-remover-lista text-red-500 hover:bg-red-500 hover:text-white px-2 py-1 rounded text-[10px] font-bold transition-colors border border-red-200 hover:border-transparent" data-pagina="noticias" data-lista="feedList" data-index="<%= realIndex %>">Apagar</button>
                        </div>
                    <% } %>

                </div>
            <% }) %>
        </div>

        <% if (totalPages > 1) { %>
            <div class="mt-16 flex items-center justify-center gap-6 hidden-scroll">
                <% if (page > 1) { %>
                    <a href="/noticias?page=<%= page - 1 %>" class="nav-link bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-brand-primary text-slate-600 dark:text-slate-300 hover:text-brand-primary px-6 py-3 rounded-full font-bold transition-all shadow-sm hover:shadow-md">← Recentes</a>
                <% } else { %>
                    <div class="px-6 py-3 invisible">← Recentes</div>
                <% } %>
                <span class="font-bold text-slate-400 text-sm tracking-widest uppercase">Página <%= page %> de <%= totalPages %></span>
                <% if (page < totalPages) { %>
                    <a href="/noticias?page=<%= page + 1 %>" class="nav-link bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-brand-primary text-slate-600 dark:text-slate-300 hover:text-brand-primary px-6 py-3 rounded-full font-bold transition-all shadow-sm hover:shadow-md">Antigas →</a>
                <% } else { %>
                    <div class="px-6 py-3 invisible">Antigas →</div>
                <% } %>
            </div>
        <% } %>

    </div>
</section>

<% const secNewsletterAtiva = siteData.config?.seccoesAtivas?.noticias_newsletter !== false; %>
<% if (secNewsletterAtiva || isAdmin) { %>
<section class="py-24 bg-grad-primary dark:bg-slate-950 transition-colors duration-500 relative overflow-hidden <%= !secNewsletterAtiva ? 'opacity-60 grayscale border-y-4 border-dashed border-red-500' : '' %>">
    
    <% if(isAdmin) { %>
        <div class="absolute top-4 left-1/2 -translate-x-1/2 z-50">
            <button class="btn-toggle-seccao <%= secNewsletterAtiva ? 'bg-slate-800' : 'bg-red-600' %> text-white px-4 py-1.5 rounded-full text-xs font-bold shadow-lg border border-white/20" data-seccao="noticias_newsletter">
                <%= secNewsletterAtiva ? '👁️ Ocultar Newsletter' : '🚫 Secção Oculta (Ativar)' %>
            </button>
        </div>
    <% } %>

    <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmYiLz48L3N2Zz4=')]"></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center w-full mt-6">
        <% if(isAdmin) { %>
            <div class="flex justify-center gap-2 mb-8 bg-black/10 backdrop-blur-sm py-2 px-4 rounded-xl w-max mx-auto border border-white/10">
                <span class="text-xs font-bold text-white/70 uppercase flex items-center mr-2">Editar Newsletter:</span>
                <button class="btn-editar-cms bg-slate-800 hover:bg-slate-900 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="newsletterIcone">Icone</button>
                <button class="btn-editar-cms bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="newsletterTitulo">Título</button>
                <button class="btn-editar-cms bg-orange-500 hover:bg-orange-600 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="newsletterTexto">Texto</button>
                <button class="btn-editar-cms bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded shadow text-xs font-bold transition-colors" data-pagina="noticias" data-chave="newsletterBtn">Botão</button>
            </div>
        <% } %>

        <span id="texto-noticias-newsletterIcone" class="hidden-scroll text-6xl mb-6 block"><%= siteData.noticias.newsletterIcone %></span>
        <h2 id="texto-noticias-newsletterTitulo" class="hidden-scroll delay-100 text-4xl md:text-5xl font-extrabold text-white mb-6"><%= siteData.noticias.newsletterTitulo %></h2>
        <p id="texto-noticias-newsletterTexto" class="hidden-scroll delay-200 text-xl text-blue-100 dark:text-slate-400 mb-10 max-w-2xl mx-auto"><%= siteData.noticias.newsletterTexto %></p>

        <form class="hidden-scroll delay-300 flex flex-col md:flex-row gap-4 max-w-2xl mx-auto relative z-20" onsubmit="event.preventDefault(); alert('Email subscrito com sucesso no protótipo!');">
            <input type="email" placeholder="<%= siteData.noticias.newsletterPlaceholder %>" required class="flex-1 px-8 py-5 rounded-full text-lg text-slate-800 outline-none focus:ring-4 focus:ring-brand-accent/50 shadow-xl border-none">
            <button type="submit" class="bg-brand-accent hover:bg-orange-500 text-white font-black text-lg px-10 py-5 rounded-full shadow-xl hover:-translate-y-1 transition-all duration-300 whitespace-nowrap">
                <span id="texto-noticias-newsletterBtn"><%= siteData.noticias.newsletterBtn %></span>
            </button>
        </form>
        <p id="texto-noticias-newsletterAviso" class="hidden-scroll delay-300 text-sm text-blue-200/60 mt-6"><%= siteData.noticias.newsletterAviso %></p>
    </div>
</section>
<% } %>
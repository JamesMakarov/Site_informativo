<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    
    <link rel="stylesheet" href="/css/style.css">
    
    <script>
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'brand-blue': '#0F172A',
                        'brand-primary': '#1D4ED8',
                        'brand-accent': '#FF6B0B',
                    },
                    backgroundImage: {
                        'grad-primary': 'linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%)',
                        'grad-dark': 'linear-gradient(135deg, #0F172A 0%, #1E293B 100%)',
                        'grad-hover': 'linear-gradient(135deg, #1E40AF 0%, #60A5FA 100%)',
                        'grad-animated': 'linear-gradient(90deg, #FF6B0B, #ff9d00, #FF6B0B)',
                    },
                    keyframes: {
                        float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-15px)' } },
                        blob: { "0%": { transform: "translate(0px, 0px) scale(1)" }, "33%": { transform: "translate(30px, -50px) scale(1.1)" }, "66%": { transform: "translate(-20px, 20px) scale(0.9)" }, "100%": { transform: "translate(0px, 0px) scale(1)" } },
                        shimmer: { "0%": { backgroundPosition: "0% 50%" }, "50%": { backgroundPosition: "100% 50%" }, "100%": { backgroundPosition: "0% 50%" } }
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'float-delayed': 'float 6s ease-in-out 3s infinite',
                        'blob': 'blob 7s infinite',
                        'blob-delayed': 'blob 7s infinite 2s',
                        'shimmer': 'shimmer 3s ease infinite',
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 overflow-x-hidden transition-colors duration-500 min-h-screen flex flex-col">

    <% if(isAdmin) { %>
        <div class="bg-red-600 text-white text-center py-2 font-bold text-xs sm:text-sm z-[101] relative flex flex-col sm:flex-row justify-center items-center gap-2 sm:gap-4 w-full shadow-md px-4">
            <span>⚠️ MODO DE EDIÇÃO ATIVADO</span>
            <a href="/sair-painel" class="underline text-red-200 hover:text-white bg-red-800/30 px-4 py-1.5 rounded-full text-xs">Sair do Modo Admin</a>
        </div>
    <% } %>
    
    <div id="loader" class="loader-overlay hidden fixed inset-0 bg-white/80 dark:bg-slate-900/80 z-[999] backdrop-blur-sm flex items-center justify-center">
        <div class="spinner border-4 border-brand-primary border-t-transparent rounded-full w-12 h-12 animate-spin"></div>
    </div>

    <header class="sticky top-0 w-full z-[100] transition-all duration-300 bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border-b border-slate-200/50 dark:border-slate-800/50 shadow-sm">
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 md:h-24 flex items-center justify-between gap-4">
            
            <div class="relative group/logo flex items-center shrink-0">
                <a href="/" class="nav-link block">
                    <img id="img-config-logo" src="<%= siteData.config?.logo || 'https://via.placeholder.com/150x50?text=Sua+Logo' %>" alt="Logo" class="h-8 sm:h-10 md:h-12 w-auto object-contain max-w-[120px] sm:max-w-[180px] transition-transform hover:scale-105">
                </a>
                <% if(isAdmin) { %>
                    <button class="absolute -bottom-2 -right-2 sm:-right-4 bg-brand-accent text-white p-1 sm:p-1.5 rounded-full shadow-lg opacity-0 group-hover/logo:opacity-100 transition-opacity z-50 text-[10px]" data-pagina="config" data-chave="logo" data-tipo="imagem" title="Mudar Logo">🖼️</button>
                <% } %>
            </div>

            <nav class="hidden lg:block">
                <ul class="flex items-center gap-6 xl:gap-8">
                    <li><a href="/" class="nav-link font-bold hover:text-brand-accent transition-colors text-brand-blue dark:text-slate-200">Início</a></li>
                    
                    <% 
                    const pAtivas = siteData.config?.paginasAtivas || {};
                    const menuItems = [
                        { id: 'historia', url: '/historia', label: 'História' },
                        { id: 'projetos', url: '/projetos', label: 'Projetos' },
                        { id: 'noticias', url: '/noticias', label: 'Notícias' },
                        { id: 'galeria', url: '/galeria', label: 'Galeria' },
                        { id: 'doacoes', url: '/doacoes', label: 'Doações' },
                        { id: 'oracao', url: '/oracao', label: 'Oração' }
                    ];
                    %>

                    <% menuItems.forEach(item => { %>
                        <% if (pAtivas[item.id] !== false || isAdmin) { %>
                            <li class="relative group/nav py-4"> 
                                <a href="<%= item.url %>" class="nav-link font-bold transition-colors <%= pAtivas[item.id] === false ? 'text-red-400 line-through opacity-70' : 'hover:text-brand-accent text-brand-blue dark:text-slate-200' %>">
                                    <%= item.label %>
                                </a>
                                <% if(isAdmin) { %>
                                    <button class="btn-toggle-pagina absolute -bottom-2 left-1/2 -translate-x-1/2 <%= pAtivas[item.id] === false ? 'bg-red-500' : 'bg-slate-700' %> hover:bg-brand-accent text-white rounded-full w-5 h-5 flex items-center justify-center opacity-0 group-hover/nav:opacity-100 transition-opacity text-[10px] shadow-lg border border-slate-600 z-50" data-pagina="<%= item.id %>" title="Ligar/Desligar Página">
                                        <%= pAtivas[item.id] === false ? '🚫' : '👁️' %>
                                    </button>
                                <% } %>
                            </li>
                        <% } %>
                    <% }) %>
                </ul>
            </nav>

            <div class="flex items-center gap-2 sm:gap-4 shrink-0">
                
                <button id="theme-toggle" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-sm p-2 transition-colors focus:outline-none">
                    <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                    <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path></svg>
                </button>

                <button id="m-menu-btn" class="lg:hidden text-slate-600 dark:text-slate-300 p-2 focus:outline-none bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-lg transition-colors">
                    <svg class="w-6 h-6 sm:w-7 sm:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </div>
        </div>

        <div id="m-menu-drop" class="lg:hidden absolute top-full left-0 w-full bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl shadow-2xl border-t border-slate-200 dark:border-slate-800 z-[90] overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0 pointer-events-none">
            <div class="px-6 py-6 flex flex-col gap-4">
                <a href="/" class="nav-link block text-lg font-bold text-slate-800 dark:text-white hover:text-brand-accent transition-colors pb-3 border-b border-slate-100 dark:border-slate-800/50">Início</a>
                
                <% menuItems.forEach(item => { %>
                    <% if (pAtivas[item.id] !== false || isAdmin) { %>
                        <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-slate-800/50">
                            <a href="<%= item.url %>" class="nav-link flex-1 text-lg font-bold <%= pAtivas[item.id] === false ? 'text-red-400 line-through' : 'text-slate-800 dark:text-white hover:text-brand-accent' %> transition-colors">
                                <%= item.label %>
                            </a>
                            <% if(isAdmin) { %>
                                <button class="btn-toggle-pagina bg-slate-100 dark:bg-slate-800 rounded-full w-8 h-8 flex items-center justify-center border border-slate-300 dark:border-slate-700 shadow-sm shrink-0" data-pagina="<%= item.id %>">
                                    <%= pAtivas[item.id] === false ? '🚫' : '👁️' %>
                                </button>
                            <% } %>
                        </div>
                    <% } %>
                <% }) %>
            </div>
        </div>
    </header>

    <main id="app-content" class="flex-1 w-full relative">
        <%- include(bodyPage) %> 
    </main>

    <footer class="bg-grad-dark text-slate-400 pt-16 pb-6 shadow-[0_-10px_30px_rgba(0,0,0,0.1)] w-full">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <div>
                <h3 class="text-2xl font-extrabold text-transparent bg-clip-text bg-grad-primary mb-4 uppercase tracking-wider">Congregação das Irmãs</h3>
                <p class="leading-relaxed">Educando com amor, servindo com esperança e vivendo a fé há mais de 50 anos na nossa comunidade.</p>
            </div>
            
            <div>
                <h3 class="text-white text-xl font-bold mb-6">Acesso Rápido</h3>
                <ul class="space-y-4">
                    <li><a href="/historia" class="nav-link footer-link hover:text-brand-accent hover:translate-x-2 transition-transform duration-300 inline-block">Nossa História</a></li>
                    <li><a href="/projetos" class="nav-link footer-link hover:text-brand-accent hover:translate-x-2 transition-transform duration-300 inline-block">Ação Social</a></li>
                    <li><a href="/vocacoes" class="nav-link footer-link hover:text-brand-accent hover:translate-x-2 transition-transform duration-300 inline-block">Vocações</a></li>
                    <li><a href="/doacoes" class="nav-link footer-link hover:text-brand-accent hover:translate-x-2 transition-transform duration-300 inline-block">Doações</a></li>
                </ul>
            </div>
            
            <div>
                <h3 class="text-white text-xl font-bold mb-6">Fale Conosco</h3>
                <p class="mb-3 flex items-center gap-2"><span class="text-xl">📍</span> Sede: Rua da Paz, 123 - Centro</p>
                <p class="mb-3 flex items-center gap-2"><span class="text-xl">📞</span> Tel: (11) 99999-9999</p>
                <p class="flex items-center gap-2"><span class="text-xl">✉️</span> contato@congregacao.org.br</p>
            </div>
        </div>
        
        <div class="max-w-7xl mx-auto px-6 text-center border-t border-slate-700/50 pt-6 text-sm flex flex-col md:flex-row justify-between items-center gap-4">
            <p>&copy; 2026 Congregação das Irmãs. Todos os direitos reservados.</p>
            <a href="/login" class="text-slate-600 hover:text-white transition-colors">Acesso Administrativo</a>
        </div>
    </footer>

    <script src="/js/main.js"></script>
    <script src="/js/carrossel.js"></script>
    <% if(isAdmin) { %>
        <script src="/js/admin.js"></script>
    <% } %>

    <script>
        document.addEventListener('click', (e) => {
            const btn = e.target.closest('#m-menu-btn');
            const menu = document.getElementById('m-menu-drop');
            if (!menu) return;

            const isOpen = menu.classList.contains('max-h-[800px]');
            const isNavLink = e.target.closest('.nav-link');
            const isToggleBtn = e.target.closest('.btn-toggle-pagina');

            // 1. Clicou no botão de abrir o menu
            if (btn) {
                if (isOpen) {
                    menu.classList.remove('max-h-[800px]', 'opacity-100', 'pointer-events-auto');
                    menu.classList.add('max-h-0', 'opacity-0', 'pointer-events-none');
                } else {
                    menu.classList.remove('max-h-0', 'opacity-0', 'pointer-events-none');
                    menu.classList.add('max-h-[800px]', 'opacity-100', 'pointer-events-auto');
                }
            } 
            // 2. Se o menu estiver aberto, fechar ao clicar fora dele OU ao clicar num link
            else if (isOpen) {
                if (!e.target.closest('#m-menu-drop') || (isNavLink && !isToggleBtn)) {
                    menu.classList.remove('max-h-[800px]', 'opacity-100', 'pointer-events-auto');
                    menu.classList.add('max-h-0', 'opacity-0', 'pointer-events-none');
                }
            }
        });
    </script>
</body>
</html>